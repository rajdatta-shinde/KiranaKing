# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection string for the app, direct for migrations.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_URL=postgresql://user:password@host/db?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string
# Comma-separated list of emails that get admin access.
ADMIN_EMAILS=admin123@gmail.com

# ── Cloudinary (product image upload) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Brevo SMTP via Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=no-reply@kiranaking.app
SENDER_NAME=KiranaKing

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── Inngest (background jobs) ───────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
